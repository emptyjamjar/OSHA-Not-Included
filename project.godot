; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="osha_not_included"
run/main_scene="uid://rwv23iayi48d"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=60
boot_splash/bg_color=Color(0.03529412, 0.039215688, 0.0627451, 1)
boot_splash/image="uid://pcl2nmgvdikv"
config/icon="uid://dos858kmgxgvu"
config/macos_native_icon="res://core/icons/OSHA.icns"
config/windows_native_icon="res://core/icons/OSHA.ico"
boot_splash/minimum_display_time=4000

[audio]

buses/default_bus_layout="uid://c1uql1fcd7q2k"

[autoload]

InteractionManager="*uid://rs788b0iptdm"
VendingSystem="*uid://dw0hnoeunims1"
Audio="*uid://cpauy0iyhojqc"
PlayerInventory="*uid://hx53g7dc4i10"
ItemSpawner="*uid://biwgn8hxrtv3d"
Dialogic="*uid://ds2q0uclmolvu"
LoadKeybinds="*uid://df1nx734uoekf"
Level_Manager="*uid://bxgyur2ge8voh"
LoadSettings="*uid://df1nx734uoekf"

[dialogic]

directories/dch_directory={
"Player": "res://ui/Timeline/Characters/Player.dch"
}
directories/dtl_directory={
"cutscene00": "res://ui/Timeline/cutscene00.dtl",
"cutscene01": "res://ui/Timeline/cutscene01.dtl",
"cutscene02": "res://cutscene02.dtl",
"cutscene03": "res://cutscene03.dtl",
