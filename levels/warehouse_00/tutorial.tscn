[sub_resource type="GDScript" id="GDScript_7sc4i"]
script/source = "extends Node2D
class_name GameManager

@onready var hud: Control = $CanvasLayer/HUD
@onready var money := 0
@onready var game_state = 0

var Ticket_Manager: TicketManager

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	Ticket_Manager = get_tree().get_first_node_in_group(\"Ticket Manager\")
	Dialogic.signal_event.connect(tut_cutscene)
	var conveyor := $Conveyor
	Ticket_Manager.on_game_start()
	$Manager.hide()
	# this starts the dialogue
	Dialogic.start(\"timeline\")
	VendingSystem.vending_bought.connect(_on_vending_bought)
	

func _on_shipper_get_money() -> void:
	money += 10
	VendingSystem.currency += 10
	hud.update_money(money)

#This is called every time you progress past a certain point in the dialogue
#And makes the fake manager move further down the path

func _on_vending_bought(item: ItemData):
	money -= item.price
	hud.update_money(money)


func tut_cutscene(argument:String) -> void:
	if argument == \"1\":
		$CutscenePath.state = 1
		Dialogic.paused = true
		Dialogic.Text.hide_textbox()
	elif argument == \"2\":
		$CutscenePath.state = 2
		Dialogic.paused = true
		Dialogic.Text.hide_textbox()
	elif argument == \"3\":
		$CutscenePath.state = 3
		Dialogic.paused = true
		Dialogic.Text.hide_textbox()
	elif argument == \"4\":
		$CutscenePath.state = 4
		Dialogic.paused = true
		Dialogic.Text.hide_textbox()
	elif argument == \"5\":
		$CutscenePath.state = 5


func _on_ticket_terminal_ticket_dialogue() -> void:
	$CutscenePath.state = 2
	Dialogic.paused = false
	Dialogic.Text.show_textbox()
	game_state += 1


func _on_conveyor_conveyor_dialogue() -> void:
	$CutscenePath.state = 3
	Dialogic.paused = false
	Dialogic.Text.show_textbox()
	game_state += 1


func _on_packager_packager_dialogue() -> void:
	$CutscenePath.state = 4
	Dialogic.paused = false
	Dialogic.Text.show_textbox()
	game_state += 1
"

