[sub_resource type="GDScript" id="GDScript_7sc4i"]
script/source = "extends Node2D
class_name GameManager

@onready var hud: Control = $CanvasLayer/HUD
@onready var money := 0
var Ticket_Manager: TicketManager

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	Ticket_Manager = get_tree().get_first_node_in_group(\"Ticket Manager\")
	Ticket_Manager.on_game_start()
	Audio.change_music_pitch(1.4, 5)

func _on_shipper_get_money() -> void:
	money += 10
	VendingSystem.currency += 10
	hud.update_money(money)

func _on_vending_bought(item: ItemData):
	money -= item.price
	hud.update_money(money)
	
"

